# ---- FactVerse secrets ----  copy to ".env" and fill in.  .env is gitignored.

# AI script/topic generation (Google AI Studio -> https://aistudio.google.com/apikey)
GEMINI_API_KEY=PASTE_YOUR_GEMINI_KEY

# Stock video (https://www.pexels.com/api/)
PEXELS_API_KEY=PASTE_YOUR_PEXELS_KEY

# Instagram account
INSTAGRAM_USERNAME=PASTE_IG_USERNAME
INSTAGRAM_PASSWORD=PASTE_IG_PASSWORD

# ---- Optional overrides (leave blank to auto-detect) ----
# FACTVERSE_HOME=        # absolute path to the project base dir
# FFMPEG_BIN=            # absolute path to ffmpeg.exe
# FFPROBE_BIN=           # absolute path to ffprobe.exe

# ---- Provider swaps for paid upgrades later (Phase: quality) ----
# ELEVENLABS_API_KEY=    # premium AI voice
# PIXABAY_API_KEY=       # alternate free stock source
